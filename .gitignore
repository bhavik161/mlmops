# =============================================================================
# MLM Platform — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!*.env.example

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ---------------------------------------------------------------------------
# Node / frontend
# ---------------------------------------------------------------------------
node_modules/
.npm
.next/
out/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# OS / IDE
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Alembic (generated SQL dumps, not migrations themselves)
# ---------------------------------------------------------------------------
*.sql.gz
