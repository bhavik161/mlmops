# =============================================================================
# MLM Platform — API Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Environment name: local | staging | production
APP_ENV=local

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# Port the FastAPI server listens on
PORT=8000

# -----------------------------------------------------------------------------
# Database (Aurora PostgreSQL 16)
# -----------------------------------------------------------------------------

# Primary connection URL (read-write)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://mlm:mlm_local@localhost:5432/mlm

# Read-replica connection URL (read-only)
# For local dev, point to the same instance as DATABASE_URL
DATABASE_URL_READ=postgresql+asyncpg://mlm:mlm_local@localhost:5432/mlm

# -----------------------------------------------------------------------------
# Redis (cache, sessions, rate-limiting)
# -----------------------------------------------------------------------------

# Redis connection URL
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Authentication — OIDC
# -----------------------------------------------------------------------------

# OIDC provider discovery URL (e.g. Cognito user pool URL, Auth0 domain, etc.)
# Must expose a /.well-known/openid-configuration endpoint
OIDC_ISSUER_URL=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>

# Expected audience claim in the JWT (usually the app client ID)
OIDC_AUDIENCE=<your-oidc-app-client-id>

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------

# AWS region where resources are deployed
AWS_REGION=us-east-1

# Optional: Leave blank when running on an EC2/ECS instance with an IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# S3 Buckets
# -----------------------------------------------------------------------------

# Stores trained model artifacts (weights, binaries, etc.)
S3_ARTIFACTS_BUCKET=mlm-artifacts-<env>

# Stores generated governance/monitoring reports
S3_REPORTS_BUCKET=mlm-reports-<env>

# Long-term archived audit log exports (immutable, versioned)
S3_AUDIT_ARCHIVE_BUCKET=mlm-audit-archive-<env>

# Temporary staging area for user-initiated uploads before processing
S3_UPLOAD_STAGING_BUCKET=mlm-upload-staging-<env>

# -----------------------------------------------------------------------------
# Data Enrichment Service (DES)
# -----------------------------------------------------------------------------

# When True, DES failures fall through silently rather than blocking requests.
# Recommended: True for local dev, False in production.
FAIL_OPEN_MODE=True
